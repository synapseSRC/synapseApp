CREATE TABLE CachedConversation (
    chat_id TEXT NOT NULL PRIMARY KEY,
    participant_id TEXT NOT NULL,
    participant_name TEXT NOT NULL,
    participant_avatar TEXT,
    last_message TEXT NOT NULL,
    last_message_time TEXT,
    unread_count INTEGER NOT NULL DEFAULT 0,
    is_online INTEGER NOT NULL DEFAULT 0,
    is_group INTEGER NOT NULL DEFAULT 0,
    cached_at INTEGER NOT NULL
);

upsertConversation:
INSERT OR REPLACE INTO CachedConversation VALUES ?;

selectAll:
SELECT * FROM CachedConversation ORDER BY last_message_time DESC;

deleteAll:
DELETE FROM CachedConversation;

deleteConversation:
DELETE FROM CachedConversation WHERE chat_id = ?;
